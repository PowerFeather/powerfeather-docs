 <office:body>
  <office:drawing>
   <draw:page draw:name="page1" draw:style-name="dp2" draw:master-page-name="Default">
    <draw:custom-shape draw:style-name="gr1" draw:text-style-name="P2" draw:layer="Pins" svg:width="2.157cm" svg:height="0.635cm" svg:x="30.589cm" svg:y="6.923cm">
     <text:p text:style-name="P1"><text:span text:style-name="T1">Ground</text:span></text:p>
